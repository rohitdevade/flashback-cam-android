<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 15 (API 35) Edge-to-Edge Styles
    
    Android 15 enforces edge-to-edge by default for apps targeting SDK 35+.
    
    CRITICAL: These deprecated APIs are ignored on Android 15:
    - android:statusBarColor
    - android:navigationBarColor  
    - android:navigationBarDividerColor
    
    Edge-to-edge is handled by:
    1. WindowCompat.setDecorFitsSystemWindows(window, false) in MainActivity.kt
    2. Flutter's SystemChrome.setEnabledSystemUIMode(SystemUiMode.edgeToEdge)
    3. App handles insets programmatically via SafeArea/MediaQuery
-->
<resources>
    <!-- Theme applied to the Android Window while the process is starting -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <!-- Enable drawing under display cutouts (always shortEdges for camera apps) -->
        <item name="android:windowLayoutInDisplayCutoutMode">always</item>
    </style>

    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
        <!-- Enable drawing under display cutouts (always shortEdges for camera apps) -->
        <item name="android:windowLayoutInDisplayCutoutMode">always</item>
    </style>
</resources>
