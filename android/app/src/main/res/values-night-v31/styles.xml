<?xml version="1.0" encoding="utf-8"?>
<!-- 
    Android 12+ (API 31) Styles - Dark Mode - COLD START OPTIMIZED
    Android 15 (API 35) Edge-to-Edge Compliant
    
    COLD START OPTIMIZATION:
    - Uses SplashScreen API for smooth app launch
    - Splash screen is for branding only - no blocking work
    - Flutter engine starts in parallel while splash shows
    
    IMPORTANT: Do NOT use deprecated APIs (API 35+):
    - android:statusBarColor
    - android:navigationBarColor
    - android:navigationBarDividerColor
-->
<resources>
    <!-- Theme applied to the Android Window while the process is starting -->
    <!-- Uses SplashScreen API for Android 12+ -->
    <style name="LaunchTheme" parent="Theme.SplashScreen">
        <!-- SplashScreen API attributes -->
        <item name="windowSplashScreenBackground">@android:color/black</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/launch_image</item>
        <item name="postSplashScreenTheme">@style/NormalTheme</item>
        
        <!-- Enable drawing under display cutouts -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@android:color/black</item>
        <!-- Enable drawing under display cutouts -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
</resources>
